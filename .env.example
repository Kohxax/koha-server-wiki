# Nuxtセッション用の秘密鍵 (32文字以上のランダム文字列)
NUXT_SESSION_PASSWORD=

# Discord OAuth (Discord Developer Portalで作成したアプリの値)
NUXT_OAUTH_DISCORD_CLIENT_ID=
NUXT_OAUTH_DISCORD_CLIENT_SECRET=

# 管理者に昇格させるDiscordユーザーID (カンマ区切り)
NUXT_ADMIN_DISCORD_IDS=

# PostgreSQL接続文字列
DATABASE_URL=postgres://koha:koha@localhost:5432/koha_wiki

# テスト用DB (vitest統合テストが使用。docker composeのdbコンテナ内に別DBとして作成する)
TEST_DATABASE_URL=postgres://koha:koha@localhost:5432/koha_wiki_test

# docker compose の db コンテナ用
POSTGRES_USER=koha
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=koha_wiki

# アップロードファイルの保存先 (省略時は ./uploads)。本番では docker compose のボリュームに合わせて /data/uploads を設定
UPLOAD_DIR=uploads

# ServerStatusの公開ホスト名から、コンテナ内から接続できる内部接続先への対応表 (JSON)。
# 同一ネットワーク内で公開IPへのヘアピンNATが使えない場合にだけ設定する。
# 例: NUXT_MINECRAFT_STATUS_TARGETS={"mc.bokukoha.dev":"192.168.1.10:25577"}
NUXT_MINECRAFT_STATUS_TARGETS=

# Cloudflare Tunnel (本番のみ)
TUNNEL_TOKEN=

# 開発用認証バイパス。本番では絶対に設定しないこと。
# NUXT_DEV_AUTH_BYPASS=1
